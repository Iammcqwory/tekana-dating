---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/site/navbar";
import { Footer } from "../../components/site/footer";
import { MessageDetailPage } from "../../components/messages/message-detail-page";

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
    { params: { id: 'user1' } },
    { params: { id: 'user2' } },
    { params: { id: 'user3' } },
  ];
}

const { id = '1' } = Astro.params;
---

<Layout title="Chat | Tekana">
  <div class="flex min-h-screen flex-col relative">
    <Navbar client:load />
    <main class="flex-1">
      <MessageDetailPage client:load id={id} />
    </main>
    <Footer client:load />
  </div>
</Layout>
