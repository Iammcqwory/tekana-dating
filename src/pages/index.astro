---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/site/navbar";
import { Footer } from "../components/site/footer";
import { AIWingman } from "../components/ai/ai-wingman";
import { Card, CardContent } from "../components/ui/card";
import { Button } from "../components/ui/button";
import { Heart, ShieldCheck, MessageSquare, Users, Sparkles, Globe } from "lucide-react";
---

<Layout title="Tekana - Find Meaningful Connections">
  <div class="flex min-h-screen flex-col relative">
    <Navbar client:load />
    <main class="flex-1">
      {/* Hero Section */}
      <section class="relative overflow-hidden bg-gradient-to-b from-background to-rose-50 dark:from-background dark:to-background py-24 md:py-32">
        <div class="container mx-auto px-4">
          <div class="grid gap-12 md:grid-cols-2 md:items-center">
            <div class="space-y-6">
              <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
                Find Meaningful <span class="text-rose-500">Connections</span>
              </h1>
              <p class="text-xl text-muted-foreground">
                Tekana connects you with compatible partners who share your values, interests, and relationship goals.
              </p>
              <div class="flex flex-col space-y-4 sm:flex-row sm:space-x-4 sm:space-y-0">
                <a href="/auth/register">
                  <Button size="lg" className="bg-rose-500 hover:bg-rose-600">
                    Create Account
                  </Button>
                </a>
                <a href="/about">
                  <Button size="lg" variant="outline">
                    Learn More
                  </Button>
                </a>
              </div>
            </div>
            <div class="relative mx-auto aspect-square max-w-md rounded-full bg-rose-100/30 p-4">
              <div class="relative h-full w-full overflow-hidden rounded-full">
                <div class="absolute inset-0 bg-gradient-to-r from-rose-500/20 to-rose-500/40 backdrop-blur-sm" />
                <div class="relative h-full w-full overflow-hidden rounded-full">
                  <div class="flex h-full items-center justify-center text-2xl font-medium text-rose-500">
                    Couple Image
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Stats Section */}
      <section class="bg-rose-50 dark:bg-rose-950/20 py-12">
        <div class="container mx-auto px-4">
          <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
            <div class="text-center">
              <p class="text-3xl font-bold text-rose-500">50K+</p>
              <p class="text-sm text-muted-foreground">Active Users</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-rose-500">10K+</p>
              <p class="text-sm text-muted-foreground">Matches Made</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-rose-500">5K+</p>
              <p class="text-sm text-muted-foreground">Success Stories</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-rose-500">4.8/5</p>
              <p class="text-sm text-muted-foreground">User Rating</p>
            </div>
          </div>
        </div>
      </section>

      {/* Features Section */}
      <section class="py-24">
        <div class="container mx-auto px-4">
          <div class="mb-16 text-center">
            <h2 class="mb-4 text-3xl font-bold md:text-4xl">Why Choose Tekana</h2>
            <p class="mx-auto max-w-2xl text-muted-foreground">
              Our platform is designed with cultural relevance, authenticity, and user safety in mind,
              making it the perfect place to find meaningful connections.
            </p>
          </div>
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <Heart className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Compatibility Focused</h3>
                <p class="text-muted-foreground">
                  Our smart matching algorithm connects you with people who share your values, interests, and relationship goals.
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <ShieldCheck className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Safety First</h3>
                <p class="text-muted-foreground">
                  Verified profiles, privacy controls, and advanced safety features to ensure a secure dating experience.
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <MessageSquare className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Meaningful Conversations</h3>
                <p class="text-muted-foreground">
                  Conversation starters and icebreakers to help you connect beyond superficial interactions.
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <Users className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Events & Community</h3>
                <p class="text-muted-foreground">
                  Virtual and in-person events designed to help you connect with others in meaningful ways.
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <Sparkles className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Quality Matches</h3>
                <p class="text-muted-foreground">
                  Our carefully curated suggestions focus on quality over quantity for more meaningful connections.
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/60 backdrop-blur transition-all hover:shadow-md">
              <CardContent className="p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 dark:bg-rose-900/30">
                  <Globe className="h-6 w-6 text-rose-500" />
                </div>
                <h3 class="mb-2 text-xl font-bold">Culturally Relevant</h3>
                <p class="text-muted-foreground">
                  Designed for African dating culture, with an understanding of local customs and relationship expectations.
                </p>
              </CardContent>
            </Card>
          </div>
        </div>
      </section>

      {/* Testimonials */}
      <section class="bg-rose-50 dark:bg-rose-950/20 py-24">
        <div class="container mx-auto px-4">
          <div class="mb-16 text-center">
            <h2 class="mb-4 text-3xl font-bold md:text-4xl">Success Stories</h2>
            <p class="mx-auto max-w-2xl text-muted-foreground">
              Hear from couples who found each other on Tekana.
            </p>
          </div>
          <div class="grid gap-8 md:grid-cols-3">
            <Card className="border-border/40 bg-background/80 backdrop-blur">
              <CardContent className="p-6">
                <div class="mb-4 flex items-center gap-4">
                  <div class="h-12 w-12 rounded-full bg-rose-100 dark:bg-rose-900/30" />
                  <div>
                    <p class="font-semibold">David & Sarah</p>
                    <p class="text-sm text-muted-foreground">Nairobi, Kenya</p>
                  </div>
                </div>
                <p class="text-muted-foreground">
                  "We matched on Tekana in 2022 and instantly connected over our shared love of hiking.
                  Six months later, we got engaged on Mount Kenya. Thank you Tekana!"
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/80 backdrop-blur">
              <CardContent className="p-6">
                <div class="mb-4 flex items-center gap-4">
                  <div class="h-12 w-12 rounded-full bg-rose-100 dark:bg-rose-900/30" />
                  <div>
                    <p class="font-semibold">Michael & Grace</p>
                    <p class="text-sm text-muted-foreground">Mombasa, Kenya</p>
                  </div>
                </div>
                <p class="text-muted-foreground">
                  "I was hesitant about dating apps, but Tekana felt different. The compatibility matching
                  introduced me to Grace, and we instantly clicked. We're now planning our wedding!"
                </p>
              </CardContent>
            </Card>
            <Card className="border-border/40 bg-background/80 backdrop-blur">
              <CardContent className="p-6">
                <div class="mb-4 flex items-center gap-4">
                  <div class="h-12 w-12 rounded-full bg-rose-100 dark:bg-rose-900/30" />
                  <div>
                    <p class="font-semibold">James & Lucy</p>
                    <p class="text-sm text-muted-foreground">Kisumu, Kenya</p>
                  </div>
                </div>
                <p class="text-muted-foreground">
                  "We both joined Tekana not expecting much, but the cultural aspects of the app made
                  it easy to find someone who shared our values. We're celebrating one year together!"
                </p>
              </CardContent>
            </Card>
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="py-24">
        <div class="container mx-auto px-4">
          <div class="rounded-xl bg-gradient-to-r from-rose-500 to-rose-600 p-8 md:p-16">
            <div class="mx-auto max-w-3xl text-center">
              <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">
                Ready to Find Your Match?
              </h2>
              <p class="mb-8 text-white/80">
                Join thousands of singles already connecting on Tekana and find your meaningful relationship today.
              </p>
              <a href="/auth/register">
                <Button size="lg" className="bg-white text-rose-600 hover:bg-white/90">
                  Get Started for Free
                </Button>
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer client:load />
    <AIWingman client:load />
  </div>
</Layout>
