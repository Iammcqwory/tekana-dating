---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/site/navbar";
import { Footer } from "../components/site/footer";
import { AIWingman } from "../components/ai/ai-wingman";
import { Card, CardContent } from "../components/ui/card";
import { Button } from "../components/ui/button";
import { Heart, ShieldCheck, MessageSquare, Users, Sparkles, Globe, ArrowRight, Star } from "lucide-react";
---

<Layout title="Tekana - Find Meaningful Connections">
  <div class="flex min-h-screen flex-col relative">
    <Navbar client:load />
    <main class="flex-1">
      {/* Hero Section */}
      <section class="relative overflow-hidden bg-background py-24 md:py-36">
        {/* Background glow effects */}
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-rose-500/10 rounded-full blur-[150px] pointer-events-none animate-pulse-glow" />
        <div class="absolute top-2/3 left-1/4 w-[400px] h-[400px] bg-rose-400/5 rounded-full blur-[100px] pointer-events-none" />
        <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-amber-500/5 rounded-full blur-[100px] pointer-events-none" />
        
        <div class="container mx-auto px-4 relative">
          <div class="grid gap-16 md:grid-cols-2 md:items-center">
            <div class="space-y-8 animate-slide-up">
              <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-rose-500/20 bg-rose-500/5 backdrop-blur text-rose-500 text-xs font-semibold tracking-wider uppercase">
                <Sparkles className="h-3.5 w-3.5" /> The Modern Way to Date
              </div>
              <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl !leading-[1.1]">
                Find Meaningful <br />
                <span class="bg-gradient-to-r from-rose-500 via-rose-400 to-amber-500 bg-clip-text text-transparent">Connections</span>
              </h1>
              <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-lg">
                Tekana connects you with compatible partners who share your values, interests, and relationship goals through cultural chemistry.
              </p>
              <div class="flex flex-col space-y-4 sm:flex-row sm:space-x-4 sm:space-y-0 pt-2">
                <a href="/auth/register">
                  <Button size="lg" className="bg-rose-500 hover:bg-rose-600 shadow-xl shadow-rose-500/20 hover:shadow-rose-500/30 text-white font-semibold px-8 h-13 rounded-xl transition-all hover:-translate-y-0.5 group">
                    Create Account
                    <ArrowRight className="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
                  </Button>
                </a>
                <a href="/about">
                  <Button size="lg" variant="outline" className="border-border/60 hover:bg-muted/40 font-medium px-8 h-13 rounded-xl transition-all">
                    Learn More
                  </Button>
                </a>
              </div>

              {/* Social proof */}
              <div class="flex items-center gap-6 pt-4">
                <div class="flex -space-x-3">
                  {[1,2,3,4].map((i) => (
                    <div class="h-10 w-10 rounded-full border-2 border-background bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center text-white text-xs font-bold shadow-sm">
                      {String.fromCharCode(64 + i)}
                    </div>
                  ))}
                </div>
                <div>
                  <div class="flex items-center gap-1 mb-0.5">
                    {[1,2,3,4,5].map(() => (
                      <Star className="h-3.5 w-3.5 fill-amber-400 text-amber-400" />
                    ))}
                  </div>
                  <p class="text-xs text-muted-foreground">Trusted by <span class="font-bold text-foreground">50K+</span> singles</p>
                </div>
              </div>
            </div>

            <div class="relative mx-auto max-w-md w-full aspect-square group animate-slide-up delay-200">
              {/* Outer decorative glowing ring */}
              <div class="absolute -inset-2 bg-gradient-to-r from-rose-500 via-rose-400 to-amber-500 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200" />
              
              <div class="relative h-full w-full overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/20 backdrop-blur-md p-3">
                <div class="relative h-full w-full overflow-hidden rounded-xl border border-white/5 bg-zinc-900/40">
                  <img 
                    src="/couple-hero.png" 
                    alt="Happy couple matched on Tekana" 
                    class="object-cover w-full h-full object-center opacity-90 transition duration-700 group-hover:scale-105"
                    loading="eager"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />
                  <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between bg-black/40 backdrop-blur-lg border border-white/10 px-5 py-3.5 rounded-xl">
                    <div>
                      <p class="text-sm font-semibold text-white">David & Sarah</p>
                      <p class="text-[11px] text-zinc-300">Matched in Nairobi</p>
                    </div>
                    <div class="flex items-center gap-1.5 bg-rose-500/20 border border-rose-500/30 px-3 py-1 rounded-full">
                      <Heart className="h-3.5 w-3.5 fill-rose-500 text-rose-500" />
                      <span class="text-xs font-bold text-rose-400">100%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Stats Section */}
      <section class="border-y border-border/40 bg-muted/30 py-12 md:py-16">
        <div class="container mx-auto px-4">
          <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
            <div class="text-center space-y-1 animate-slide-up">
              <p class="text-3xl md:text-4xl font-extrabold bg-gradient-to-b from-rose-500 to-rose-600 bg-clip-text text-transparent">50K+</p>
              <p class="text-sm text-muted-foreground font-medium">Active Users</p>
            </div>
            <div class="text-center space-y-1 animate-slide-up delay-100">
              <p class="text-3xl md:text-4xl font-extrabold bg-gradient-to-b from-rose-500 to-rose-600 bg-clip-text text-transparent">10K+</p>
              <p class="text-sm text-muted-foreground font-medium">Matches Made</p>
            </div>
            <div class="text-center space-y-1 animate-slide-up delay-200">
              <p class="text-3xl md:text-4xl font-extrabold bg-gradient-to-b from-rose-500 to-rose-600 bg-clip-text text-transparent">5K+</p>
              <p class="text-sm text-muted-foreground font-medium">Success Stories</p>
            </div>
            <div class="text-center space-y-1 animate-slide-up delay-300">
              <p class="text-3xl md:text-4xl font-extrabold bg-gradient-to-b from-rose-500 to-rose-600 bg-clip-text text-transparent">4.8/5</p>
              <p class="text-sm text-muted-foreground font-medium">User Rating</p>
            </div>
          </div>
        </div>
      </section>

      {/* Features Section */}
      <section class="py-24 md:py-32 relative">
        <div class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-rose-500/5 rounded-full blur-[120px] pointer-events-none" />
        <div class="container mx-auto px-4 relative">
          <div class="mb-16 text-center space-y-4">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-rose-500/20 bg-rose-500/5 text-rose-500 text-xs font-semibold tracking-wider uppercase mx-auto">
              <Heart className="h-3.5 w-3.5" /> Why Tekana
            </div>
            <h2 class="text-3xl font-bold md:text-4xl lg:text-5xl tracking-tight">Why Choose Tekana</h2>
            <p class="mx-auto max-w-2xl text-muted-foreground text-lg">
              Our platform is designed with cultural relevance, authenticity, and user safety in mind,
              making it the perfect place to find meaningful connections.
            </p>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <Heart className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Compatibility Focused</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Our smart matching algorithm connects you with people who share your values, interests, and relationship goals.
                </p>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <ShieldCheck className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Safety First</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Verified profiles, privacy controls, and advanced safety features to ensure a secure dating experience.
                </p>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <MessageSquare className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Meaningful Conversations</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Conversation starters and icebreakers to help you connect beyond superficial interactions.
                </p>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <Users className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Events & Community</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Virtual and in-person events designed to help you connect with others in meaningful ways.
                </p>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <Sparkles className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Quality Matches</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Our carefully curated suggestions focus on quality over quantity for more meaningful connections.
                </p>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/60 backdrop-blur transition-all duration-300 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/10 transition-colors group-hover:bg-rose-500/20">
                  <Globe className="h-7 w-7 text-rose-500" />
                </div>
                <h3 class="mb-3 text-xl font-bold">Culturally Relevant</h3>
                <p class="text-muted-foreground leading-relaxed">
                  Designed for African dating culture, with an understanding of local customs and relationship expectations.
                </p>
              </CardContent>
            </Card>
          </div>
        </div>
      </section>

      {/* Testimonials */}
      <section class="bg-muted/30 border-y border-border/40 py-24 md:py-32">
        <div class="container mx-auto px-4">
          <div class="mb-16 text-center space-y-4">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-rose-500/20 bg-rose-500/5 text-rose-500 text-xs font-semibold tracking-wider uppercase mx-auto">
              <Star className="h-3.5 w-3.5" /> Love Stories
            </div>
            <h2 class="text-3xl font-bold md:text-4xl lg:text-5xl tracking-tight">Success Stories</h2>
            <p class="mx-auto max-w-2xl text-muted-foreground text-lg">
              Hear from couples who found each other on Tekana.
            </p>
          </div>
          <div class="grid gap-8 md:grid-cols-3">
            <Card className="group border-border/40 bg-card/80 backdrop-blur transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-4 flex items-center gap-1">
                  {[1,2,3,4,5].map(() => (
                    <Star className="h-4 w-4 fill-amber-400 text-amber-400" />
                  ))}
                </div>
                <p class="text-muted-foreground mb-6 leading-relaxed italic">
                  "We matched on Tekana in 2022 and instantly connected over our shared love of hiking.
                  Six months later, we got engaged on Mount Kenya. Thank you Tekana!"
                </p>
                <div class="flex items-center gap-4 pt-4 border-t border-border/40">
                  <div class="h-12 w-12 rounded-full bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                    DS
                  </div>
                  <div>
                    <p class="font-semibold">David & Sarah</p>
                    <p class="text-sm text-muted-foreground">Nairobi, Kenya</p>
                  </div>
                </div>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/80 backdrop-blur transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-4 flex items-center gap-1">
                  {[1,2,3,4,5].map(() => (
                    <Star className="h-4 w-4 fill-amber-400 text-amber-400" />
                  ))}
                </div>
                <p class="text-muted-foreground mb-6 leading-relaxed italic">
                  "I was hesitant about dating apps, but Tekana felt different. The compatibility matching
                  introduced me to Grace, and we instantly clicked. We're now planning our wedding!"
                </p>
                <div class="flex items-center gap-4 pt-4 border-t border-border/40">
                  <div class="h-12 w-12 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                    MG
                  </div>
                  <div>
                    <p class="font-semibold">Michael & Grace</p>
                    <p class="text-sm text-muted-foreground">Mombasa, Kenya</p>
                  </div>
                </div>
              </CardContent>
            </Card>
            <Card className="group border-border/40 bg-card/80 backdrop-blur transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <CardContent className="p-8">
                <div class="mb-4 flex items-center gap-1">
                  {[1,2,3,4,5].map(() => (
                    <Star className="h-4 w-4 fill-amber-400 text-amber-400" />
                  ))}
                </div>
                <p class="text-muted-foreground mb-6 leading-relaxed italic">
                  "We both joined Tekana not expecting much, but the cultural aspects of the app made
                  it easy to find someone who shared our values. We're celebrating one year together!"
                </p>
                <div class="flex items-center gap-4 pt-4 border-t border-border/40">
                  <div class="h-12 w-12 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                    JL
                  </div>
                  <div>
                    <p class="font-semibold">James & Lucy</p>
                    <p class="text-sm text-muted-foreground">Kisumu, Kenya</p>
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="py-24 md:py-32">
        <div class="container mx-auto px-4">
          <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-rose-500 via-rose-600 to-rose-700 p-10 md:p-20">
            {/* Decorative elements */}
            <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px] pointer-events-none" />
            <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-rose-400/30 rounded-full blur-[80px] pointer-events-none" />
            
            <div class="mx-auto max-w-3xl text-center relative">
              <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/20 bg-white/10 text-white text-xs font-semibold tracking-wider uppercase mb-6">
                <Heart className="h-3.5 w-3.5" /> Start Your Journey
              </div>
              <h2 class="mb-5 text-3xl font-extrabold text-white md:text-5xl tracking-tight !leading-[1.15]">
                Ready to Find Your Match?
              </h2>
              <p class="mb-10 text-lg text-white/80 max-w-xl mx-auto">
                Join thousands of singles already connecting on Tekana and find your meaningful relationship today.
              </p>
              <a href="/auth/register">
                <Button size="lg" className="bg-white text-rose-600 hover:bg-white/90 shadow-2xl shadow-black/20 font-bold px-10 h-14 rounded-xl text-base transition-all hover:-translate-y-0.5">
                  Get Started for Free
                  <ArrowRight className="ml-2 h-5 w-5" />
                </Button>
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer client:load />
    <AIWingman client:load />
  </div>
</Layout>
